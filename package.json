{
  "name": "soundbot-electron",
  "version": "0.1.1-alpha",
  "description": "SoundBot - AI 音效管理器桌面版",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build": "electron-builder",
    "build:mac": "electron-builder --mac",
    "build:win": "electron-builder --win",
    "build:linux": "electron-builder --linux",
    "pack": "electron-builder --dir",
    "postinstall": "electron-builder install-app-deps",
    "download:models": "python scripts/download_manager.py download models",
    "download:venv": "python scripts/download_manager.py download venv",
    "download:all": "python scripts/download_manager.py download all",
    "setup": "python scripts/download_manager.py setup"
  },
  "keywords": ["electron", "audio", "sound", "manager", "ai", "semantic-search", "clap"],
  "author": "Nagisa_Huckrick (胡杨) <Nagisa_Huckrick@yeah.net>",
  "license": "GPL-3.0",
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0"
  },
  "build": {
    "appId": "com.soundbot.app",
    "productName": "SoundBot",
    "copyright": "Copyright © 2026 Nagisa_Huckrick (胡杨)",
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "files": [
      "main.js",
      "preload.js",
      "index.html",
      "tailwindcss.js",
      "lucide.min.js",
      "wavesurfer.min.js",
      "wavesurfer.regions.min.js",
      "assets/**/*",
      "config/**/*",
      "scripts/download_manager.py",
      "download_config.json",
      "!backend/__pycache__",
      "!backend/db/*.db",
      "!backend/**/*.pyc",
      "!backend/venv/**",
      "!backend/models/**",
      "!models/**",
      "!downloads/**"
    ],
    "extraResources": [
      {
        "from": "backend",
        "to": "backend",
        "filter": [
          "**/*",
          "!__pycache__",
          "!db/*.db",
          "!**/*.pyc",
          "!venv/**",
          "!models/**"
        ]
      }
    ],
    "mac": {
      "category": "public.app-category.music",
      "target": [
        {
          "target": "dmg",
          "arch": ["x64", "arm64"]
        }
      ],
      "icon": "build/icon.icns"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ],
      "icon": "build/icon.png"
    },
    "linux": {
      "target": ["AppImage"],
      "category": "AudioVideo"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "publish": null
  }
}
